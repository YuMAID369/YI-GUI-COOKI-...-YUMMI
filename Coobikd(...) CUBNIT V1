-- Sistema de Navegação Dinâmica entre Páginas (Ajustes de Posição, Alinhamento e Fontes)
local currentPage = 1
local function updateNavigation(page)
    currentPage = page
    PageAbout.Visible = (page == 1)
    PageScripts.Visible = (page == 2)
    PageExtension.Visible = (page == 3)
    RightFixedPanel.Visible = (page == 3)
    
    if page == 1 then
        Title.Text = "Sobre o CUBNIT/Spawnismo"
        Title.Font = Enum.Font.LuckiestGuy
        Title.Size = UDim2.new(1, 0, 0, 50)
        Title.Position = UDim2.new(0, 0, 0, 6)
        Title.TextXAlignment = Enum.TextXAlignment.Center -- [AJUSTE]: Centralizado na parte superior
        LeftBtn.Visible = false
        RightBtn.Visible = true
        WhiteSeparator.Visible = true
        FooterBar.Visible = true
    elseif page == 2 then
        Title.Text = "BROOKHAVEN"
        Title.Font = Enum.Font.LuckiestGuy
        Title.Size = UDim2.new(1, 0, 0, 55)
        Title.Position = UDim2.new(0, 0, 0, 5)
        Title.TextXAlignment = Enum.TextXAlignment.Center -- [AJUSTE]: Nome exatamente no Meio da tela
        LeftBtn.Visible = true
        RightBtn.Visible = true
        WhiteSeparator.Visible = true
        FooterBar.Visible = true
    elseif page == 3 then
        Title.Text = "SPWN EXTENSION"
        Title.Font = Enum.Font.LuckiestGuy -- [AJUSTE]: Mesma fonte grossa e marcante das abas anteriores
        Title.Size = UDim2.new(1, -120, 0, 50)
        Title.Position = UDim2.new(0, 55, 0, 5) 
        Title.TextXAlignment = Enum.TextXAlignment.Left -- Alinhado ao lado do botão voltar (<)
        LeftBtn.Visible = true
        RightBtn.Visible = false
        WhiteSeparator.Visible = false 
        FooterBar.Visible = false
    end
end

RightBtn.MouseButton1Click:Connect(function() if currentPage < 3 then updateNavigation(currentPage + 1) end end)
LeftBtn.MouseButton1Click:Connect(function() if currentPage > 1 then updateNavigation(currentPage - 1) end end)


