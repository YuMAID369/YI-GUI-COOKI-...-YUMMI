local function AddButton(name, link)
    local btn = Instance.new("TextButton", ScrollingFrame)
    btn.Name = name
    btn.BackgroundColor3 = Color3.fromRGB(75, 20, 20)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 16
    btn.Font = Enum.Font.SourceSansBold
    btn.TextWrapped = true 
    btn.TextScaled = true 
    btn.TextStrokeTransparency = 1
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(120, 120, 120)
    
    local p = Instance.new("UIPadding", btn)
    p.PaddingLeft, p.PaddingRight = UDim.new(0, 2), UDim.new(0, 2)
    
    -- Execução via Loadstring
    btn.MouseButton1Click:Connect(function()
        if link then
            loadstring(game:HttpGet(link))()
        end
    end)
end

-- Gerar botões a partir da tabela
for name, link in pairs(ScriptData) do
    AddButton(name, link)
end

