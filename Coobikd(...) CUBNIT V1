local function AddButton(name, link)
    local btn = Instance.new("TextButton", ScrollingFrame)
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35) -- Cinza Chumbo da imagem
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 14
    btn.Font = Enum.Font.SourceSansBold
    btn.TextWrapped = true 
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(100, 100, 100) -- Borda clara sutil
    
    local p = Instance.new("UIPadding", btn)
    p.PaddingLeft, p.PaddingRight = UDim.new(0, 4), UDim.new(0, 4)
    
    btn.MouseButton1Click:Connect(function()
        if link then
            loadstring(game:HttpGet(link))()
        end
    end)
end

for name, link in pairs(ScriptData) do
    AddButton(name, link)
end

