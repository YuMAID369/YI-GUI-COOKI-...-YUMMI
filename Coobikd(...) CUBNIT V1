-- 7. LÓGICA DE CONTROLE EXTERNO (SINGLE E DOUBLE CLICK)
local lastClick = 0
OpenBtn.MouseButton1Click:Connect(function()
    local currentTime = tick()
    
    -- Lógica de Double Click (Intervalo menor que 0.35 segundos para Kill Switch)
    if (currentTime - lastClick) < 0.35 then
        ScreenGui:Destroy() -- Deleta o script completamente
    else
        -- Lógica de Single Click (Toggle Visibilidade)
        MainFrame.Visible = not MainFrame.Visible
    end
    
    lastClick = currentTime
end)
