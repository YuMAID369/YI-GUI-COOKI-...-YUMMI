-- Lógica de Transição entre Abas
local function updateNavigation(page)
    if page == 1 then
        PageAbout.Visible = true
        PageScripts.Visible = false
        Title.Text = "Sobre o CUBNIT/ Spawnismo"
        LeftBtn.Visible = false
        RightBtn.Visible = true
    else
        PageAbout.Visible = false
        PageScripts.Visible = true
        Title.Text = "BROOKHAVEN"
        LeftBtn.Visible = true
        RightBtn.Visible = false
    end
end

RightBtn.MouseButton1Click:Connect(function() updateNavigation(2) end)
LeftBtn.MouseButton1Click:Connect(function() updateNavigation(1) end)

