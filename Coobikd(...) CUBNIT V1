-- Sistema de Navegação Dinâmica entre Páginas
local currentPage = 1
local function updateNavigation(page)
    currentPage = page
    PageAbout.Visible = (page == 1)
    PageScripts.Visible = (page == 2)
    PageTools.Visible = (page == 3)
    WhiteBarSeparator.Visible = (page == 3)

    if page == 1 then
        Title.Text = "Sobre o CUBNIT/Spawnismo"
        Title.Size = UDim2.new(1, 0, 0, 50)
        Title.Position = UDim2.new(0, 0, 0, 5)
        LeftBtn.Visible = false
        RightBtn.Visible = true
    elseif page == 2 then
        Title.Text = "BROOKHAVEN"
        Title.Size = UDim2.new(1, 0, 0, 50)
        Title.Position = UDim2.new(0, 0, 0, 5)
        LeftBtn.Visible = true
        RightBtn.Visible = true
    elseif page == 3 then
        Title.Text = "Painel Tool ( Spwn Shortcuts )"
        Title.Size = UDim2.new(1, -100, 0, 50)
        Title.Position = UDim2.new(0, 50, 0, 5)
        LeftBtn.Visible = true
        RightBtn.Visible = false
    end
end

RightBtn.MouseButton1Click:Connect(function() 
    if currentPage < 3 then 
        PlayClickSound()
        updateNavigation(currentPage + 1) 
    end 
end)
LeftBtn.MouseButton1Click:Connect(function() 
    if currentPage > 1 then 
        PlayClickSound()
        updateNavigation(currentPage - 1) 
    end 
end)


