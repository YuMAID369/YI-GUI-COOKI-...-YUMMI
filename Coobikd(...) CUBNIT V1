-- EXECUÇÃO COMPACTA DA ANIMAÇÃO (SPIN-AND-FIX)
-- ==========================================
task.spawn(function()
    task.wait(0.1)
    local infoE, infoB, infoI, infoD = TweenInfo.new(1.3, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), TweenInfo.new(1.8, Enum.EasingStyle.Quint, Enum.EasingDirection.InOut), TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

    TweenService:Create(IconImage, infoE, {Position = UDim2.new(0.5, 0, 0.5, 0), ImageTransparency = 0}):Play()
    TweenService:Create(IconImage, infoE, {Rotation = 720}):Play()
    TweenService:Create(Background, infoB, {BackgroundTransparency = 0.20}):Play()

    task.wait(1.2)
    local fix = TweenService:Create(IconImage, infoI, {Size = UDim2.new(0, 260, 0, 260), Rotation = 0}); fix:Play(); fix.Completed:Wait()
    task.wait(1.5)

    TweenService:Create(Background, infoD, {BackgroundTransparency = 1}):Play()
    local dissipate = TweenService:Create(IconImage, infoD, {Size = UDim2.new(0, 400, 0, 400), ImageTransparency = 1}); dissipate:Play()
    TweenService:Create(OpenBtn, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {ImageTransparency = 0}):Play()

    dissipate.Completed:Wait()
    IntroGui:Destroy()
end)
